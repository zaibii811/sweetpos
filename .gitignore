# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# Dependencies
node_modules/
.pnpm-store/

# Environment variables — NEVER commit these
.env
.env.local
.env.production
.env.production.local
# NOTE: .env.example files ARE intentionally committed

# Database files
db/*.db
*.db
*.sqlite
uploads/*.csv

# Logs
*.log
logs/
npm-debug.log
yarn-error.log
pnpm-debug.log*

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# System files
.DS_Store
Thumbs.db
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
/typings

# Replit-specific — not needed in GitHub
.replit
replit.nix
.cache/
.local/
.upm/
__pycache__/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
